{
    "name": "study-abroad-website",
    "version": "1.0.0",
    "description": "Modern study abroad agency website",
    "scripts": {
        "dev": "npm run build:css && npm run build:js",
        "build": "npm run build:css && npm run build:js",
        "build:css": "tailwindcss -i ./src/assets/css/input.css -o ./public/assets/css/style.css --watch",
        "build:js": "webpack --mode development --watch",
        "build:prod": "npm run build:css:prod && npm run build:js:prod",
        "build:css:prod": "tailwindcss -i ./src/assets/css/input.css -o ./public/assets/css/style.css --minify",
        "build:js:prod": "webpack --mode production"
    },
    "devDependencies": {
        "tailwindcss": "^3.3.0",
        "autoprefixer": "^10.4.0",
        "postcss": "^8.4.0",
        "webpack": "^5.88.0",
        "webpack-cli": "^5.1.0",
        "babel-loader": "^9.1.0",
        "@babel/core": "^7.22.0",
        "@babel/preset-env": "^7.22.0"
    },
    "dependencies": {
        "aos": "^2.3.4",
        "lottie-web": "^5.12.0",
        "swiper": "^10.0.0",
        "flatpickr": "^4.6.0",
        "chart.js": "^4.3.0",
        "sortablejs": "^1.15.0",
        "dropzone": "^6.0.0"
    }
}